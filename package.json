{
  "name": "pactolus",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @pactolus/api dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @pactolus/db db:generate",
    "db:migrate": "pnpm --filter @pactolus/db db:migrate",
    "db:studio": "pnpm --filter @pactolus/db db:studio",
    "db:seed": "pnpm --filter @pactolus/db db:seed"
  }
}
