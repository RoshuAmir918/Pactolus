{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@api/*": ["apps/api/src/*"],
      "@db/*": ["packages/db/src/*"],
      "@worker/*": ["apps/worker/src/*"]
    },
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts", "scripts/**/*.ts", "types/**/*.d.ts"]
}
