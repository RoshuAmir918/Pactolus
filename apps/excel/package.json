{
  "name": "@pactolus/excel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host localhost --port 3001",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host localhost --port 3001",
    "sideload": "office-addin-debugging start manifest.xml desktop --app excel",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "start": "npm-run-all -p dev sideload"
  },
  "devDependencies": {
    "@trpc/client": "^11.11.0",
    "@types/office-js": "^1.0.581",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "npm-run-all": "^4.1.5",
    "office-addin-debugging": "^6.0.6",
    "office-addin-manifest": "^2.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jotai": "^2.19.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  }
}
