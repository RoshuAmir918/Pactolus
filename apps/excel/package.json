{
  "name": "@pactolus/excel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host localhost --port 3001",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host localhost --port 3001",
    "sideload": "office-addin-debugging start manifest.xml desktop --app excel",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "start": "npm-run-all -p dev sideload"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.581",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "npm-run-all": "^4.1.5",
    "office-addin-debugging": "^6.0.6",
    "office-addin-manifest": "^2.1.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }
}
